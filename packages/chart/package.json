{
  "name": "react-native-nitro-charts",
  "version": "0.0.2",
  "private": false,
  "description": "High-performance charting primitives for Expo apps using Skia, D3, and Nitro.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vaib215/react-native-nitro-charts.git"
  },
  "homepage": "https://github.com/Vaib215/react-native-nitro-charts#readme",
  "bugs": {
    "url": "https://github.com/Vaib215/react-native-nitro-charts/issues"
  },
  "keywords": [
    "react-native",
    "expo",
    "charts",
    "skia",
    "nitro",
    "data-visualization"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "files": [
    "dist",
    "src",
    "nitrogen/generated",
    "android",
    "ios",
    "cpp",
    "nitro.json",
    "expo-module.config.json",
    "*.podspec"
  ],
  "scripts": {
    "nitrogen": "node ../../node_modules/.bun/node_modules/nitrogen/lib/index.js .",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": "*",
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "react-native-nitro-modules": "^0.33.0"
  },
  "devDependencies": {
    "nitrogen": "^0.33.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./dist/index.js"
    }
  }
}
