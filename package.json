{
  "name": "chart-workspace",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter react-native-nitro-charts build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "example": "bun run --cwd apps/example start",
    "example:android": "bun run --cwd apps/example android",
    "example:ios": "bun run --cwd apps/example ios",
    "example:web": "bun run --cwd apps/example web",
    "example:web:setup-skia": "bun run --cwd apps/example web:setup-skia"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.8.3"
  }
}
